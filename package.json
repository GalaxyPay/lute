{
  "name": "lute",
  "displayName": "Lute",
  "version": "1.23.9",
  "type": "module",
  "description": "An Algorand Wallet",
  "license": "AGPL-3.0-only",
  "scripts": {
    "dev": "vite",
    "devx": "npm run clear && cross-env NODE_ENV=development run-p devx:*",
    "devx:prepare": "esno scripts/prepare.ts",
    "devx:background": "npm run buildx:background -- --mode development",
    "devx:web": "vite --config vite.config.ext.mts",
    "devx:js": "npm run buildx:js -- --mode development",
    "build": "vite build",
    "buildx": "cross-env NODE_ENV=production run-s clear buildx:web buildx:prepare buildx:background buildx:js",
    "buildx:prepare": "esno scripts/prepare.ts",
    "buildx:background": "vite build --config vite.config.background.mts",
    "buildx:web": "vite build --config vite.config.ext.mts",
    "buildx:js": "vite build --config vite.config.content.mts",
    "preview": "vite preview",
    "clear": "rimraf --glob extension/dist extension/manifest.json extension.*",
    "lint": "eslint . --fix",
    "type-check": "vue-tsc -b"
  },
  "dependencies": {
    "@algorandfoundation/algokit-utils": "^9.2.0",
    "@algorandfoundation/xhd-wallet-api": "2.0.0-canary.1",
    "@ledgerhq/hw-transport-webhid": "^6.35.4",
    "@ledgerhq/hw-transport-webusb": "^6.34.4",
    "@mdi/js": "^7.4.47",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@scure/bip32": "^2.2.0",
    "@scure/bip39": "^2.2.0",
    "algosdk": "^3.6.0",
    "canonify": "^2.1.1",
    "falcon-1024": "^0.1.3",
    "idb": "^8.0.3",
    "ledger-algorand-js": "^0.0.1",
    "micro-key-producer": "^0.9.0",
    "multiformats": "^13.4.2",
    "pinia": "^3.0.4",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0",
    "vuetify": "^3.12.8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@types/bn.js": "^5.2.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.4",
    "@types/w3c-web-hid": "^1.0.7",
    "@types/w3c-web-usb": "^1.0.14",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/tsconfig": "^0.9.1",
    "chokidar": "^5.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.9.2",
    "esno": "^4.8.0",
    "fs-extra": "^11.3.5",
    "kolorist": "^1.8.0",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "unplugin-auto-import": "^20.3.0",
    "unplugin-vue-components": "^30.0.0",
    "vite": "^7.3.5",
    "vite-plugin-node-polyfills": "^0.28.0",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-sri-gen": "^1.6.1",
    "vite-plugin-vuetify": "^2.1.3",
    "vue-tsc": "^3.3.5",
    "webext-bridge": "^6.0.1",
    "webextension-polyfill": "^0.12.0"
  },
  "engines": {
    "node": ">=22.16.0"
  }
}
