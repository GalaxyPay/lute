{
  "name": "lute",
  "displayName": "Lute",
  "version": "1.23.5",
  "type": "module",
  "description": "An Algorand Wallet",
  "license": "AGPL-3.0-only",
  "scripts": {
    "dev": "vite",
    "devx": "npm run clear && cross-env NODE_ENV=development run-p devx:*",
    "devx:prepare": "esno scripts/prepare.ts",
    "devx:background": "npm run buildx:background -- --mode development",
    "devx:web": "vite --config vite.config.ext.mts",
    "devx:js": "npm run buildx:js -- --mode development",
    "build": "vite build",
    "buildx": "cross-env NODE_ENV=production run-s clear buildx:web buildx:prepare buildx:background buildx:js",
    "buildx:prepare": "esno scripts/prepare.ts",
    "buildx:background": "vite build --config vite.config.background.mts",
    "buildx:web": "vite build --config vite.config.ext.mts",
    "buildx:js": "vite build --config vite.config.content.mts",
    "preview": "vite preview",
    "clear": "rimraf --glob extension/dist extension/manifest.json extension.*",
    "lint": "eslint . --fix"
  },
  "dependencies": {
    "@algorandfoundation/algokit-utils": "^9.2.0",
    "@ledgerhq/hw-transport-webhid": "^6.34.0",
    "@ledgerhq/hw-transport-webusb": "^6.33.0",
    "@mdi/js": "^7.4.47",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@scure/bip32": "^2.0.1",
    "@scure/bip39": "^2.0.1",
    "algosdk": "^3.5.2",
    "bn.js": "^5.2.3",
    "canonify": "^2.1.1",
    "falcon-1024": "^0.1.3",
    "idb": "^8.0.3",
    "ledger-algorand-js": "^0.0.1",
    "micro-key-producer": "^0.8.5",
    "multiformats": "^13.4.2",
    "pinia": "^3.0.4",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4",
    "vuetify": "^3.12.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@types/bn.js": "^5.2.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.0",
    "@types/w3c-web-hid": "^1.0.7",
    "@types/w3c-web-usb": "^1.0.14",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.8.1",
    "chokidar": "^5.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.8.0",
    "esno": "^4.8.0",
    "fs-extra": "^11.3.4",
    "kolorist": "^1.8.0",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^20.3.0",
    "unplugin-vue-components": "^30.0.0",
    "vite": "^7.3.1",
    "vite-plugin-node-polyfills": "^0.24.0",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-sri-gen": "^1.3.2",
    "vite-plugin-vuetify": "^2.1.3",
    "vue-tsc": "^3.2.6",
    "webext-bridge": "^6.0.1",
    "webextension-polyfill": "^0.12.0"
  },
  "engines": {
    "node": ">=22.16.0"
  }
}
